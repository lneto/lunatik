#!/usr/bin/lua5.4
--
-- SPDX-FileCopyrightText: (c) 2023-2026 Ring Zero Desenvolvimento de Software LTDA
-- SPDX-License-Identifier: MIT OR GPL-2.0-only
--

local config = require("lunatik.config")

local lunatik = {
	copyright = "Copyright (C) 2023-2026 Ring Zero Desenvolvimento de Software LTDA.",
	device = "/dev/lunatik",
	modules = config.modules,
}

function lunatik.prompt()
	io.write("> ")
	io.flush()
end

function lunatik.open(mode)
	return io.open(lunatik.device, mode)
end

function lunatik.probe()
	return os.execute("[ -e " .. lunatik.device .. " ]")
end

function lunatik.loadstring(chunk)
	local loader <close> = assert(lunatik.open("r+"))
	loader:write(chunk)
end

function lunatik.result()
	local reader <close> = lunatik.open("r")
	return reader:read("a")
end

function lunatik.dostring(chunk)
	lunatik.loadstring(chunk)
	return lunatik.result()
end

function lunatik.usage()
	print("usage: lunatik [load|unload|reload|status|list] [run|spawn|stop <script>] [seal <script>]")
	os.exit(false)
end

function lunatik.sh(command, module, loaded)
	local isloaded = loaded and "&&" or "||"
	os.execute(string.format("MODULE=%s;grep -wq $MODULE /proc/modules %s%s", module, isloaded, command))
end

lunatik.commands = {
	['load'] = function ()
		for _, module in ipairs(lunatik.modules) do
			lunatik.sh("modprobe $MODULE", module)
		end

		if not lunatik.probe() then
			error("couldn't create " .. lunatik.device)
		end

		local result = lunatik.dostring[[
			lunatik = require("lunatik")
			lunatik.runner = require("lunatik.runner")
			lunatik.runner.startup()
		]]
		if result ~= "" then error(result) end
	end,
	['unload'] = function ()
		if lunatik.probe() then
			lunatik.dostring("lunatik.runner.shutdown()")
		end

		local first = #lunatik.modules
		for i = first, 1, -1 do
			local module = lunatik.modules[i]
			lunatik.sh("rmmod $MODULE", module, true)
		end
	end,
	['reload'] = function()
		local commands = lunatik.commands
		commands.unload()
		commands.load()
	end,
	['status'] = function ()
		for _, module in ipairs(lunatik.modules) do
			lunatik.sh("echo $MODULE is loaded || echo $MODULE is not loaded", module, true)
		end
	end
}

local command = lunatik.commands[arg[1]]
if command then
	command()
	os.exit()
end

function lunatik.load()
	if not lunatik.probe() then
		lunatik.commands.load()
	end
end

local function readfile(path)
	local f <close> = assert(io.open(path, "rb"))
	return f:read("a")
end

local function bin2hex(s)
	return string.format(string.rep("%.2x", #s), string.unpack(string.rep("B", #s), s))
end

function lunatik.seal(input)
	if not input then
		io.stderr:write("usage: lunatik seal <script.lua>\n")
		os.exit(false)
	end

	local name = input:match("([^/]+)%.lua$")
	if not name then
		error("input must be a .lua file")
	end

	lunatik.load()

	-- generate random key (32 bytes) and nonce (12 bytes)
	local urand <close> = assert(io.open("/dev/urandom", "rb"))
	local key = urand:read(32)
	local nonce = urand:read(12)
	local key_hex = bin2hex(key)
	local nonce_hex = bin2hex(nonce)

	-- read plaintext and hex-encode
	local plaintext = readfile(input)
	local pt_hex = bin2hex(plaintext)

	-- encrypt via kernel crypto
	local encrypt_chunk = string.format(
		"local a=require('crypto.aead') local u=require('util') " ..
		"local c=a.new('gcm(aes)') c:setkey((u.hex2bin('%s'))) c:setauthsize(16) " ..
		"local ct=c:encrypt((u.hex2bin('%s')),(u.hex2bin('%s'))) c:close() " ..
		"return (u.bin2hex(ct))",
		key_hex, nonce_hex, pt_hex)

	local ct_hex = lunatik.dostring(encrypt_chunk)
	if ct_hex == "" or ct_hex:find("[^0-9a-f]") then
		error("encryption failed: " .. ct_hex)
	end

	-- store key+nonce blob in _ENV[name]
	local store_chunk = string.format(
		"local d=require('data').new(44) local u=require('util') " ..
		"d:setstring(0,(u.hex2bin('%s'))) d:setstring(32,(u.hex2bin('%s'))) " ..
		"lunatik._ENV['%s']=d",
		key_hex, nonce_hex, name)

	local result = lunatik.dostring(store_chunk)
	if result ~= "" then
		error("failed to store key blob: " .. result)
	end

	-- write sealed loader
	local output = input:gsub("%.lua$", ".sealed.lua")
	local f <close> = assert(io.open(output, "w"))
	f:write(string.format(
		"-- sealed script generated by lunatik seal\n" ..
		"local seal = require(\"seal\")\n" ..
		"local util = require(\"util\")\n" ..
		"return seal.run(util.hex2bin(\"%s\"), \"%s\")\n",
		ct_hex, name))

	print("Sealed: " .. input .. " -> " .. output)
end

local function set(t)
	local s = {}
	for _, key in ipairs(t) do s[key] = true end
	return s
end

local tokens = set{"run", "spawn", "stop", "list"}

if #arg >= 1 then
	local token = arg[1]
	local script = arg[2]
	local parm = arg[3]
	if token == "seal" then
		lunatik.seal(script)
		os.exit()
	elseif tokens[token] then
		lunatik.load()
		local parm = parm and ("," .. parm) or ""
		local ret = token == "list" and "return" or ""
		local chunk = string.format("%s lunatik.runner.%s('%s'%s)", ret, token, script, parm)
		print(lunatik.dostring(chunk))
	else
		lunatik.usage()
	end
	os.exit()
end

lunatik.load()
local version = lunatik.dostring("return _LUNATIK_VERSION")
lunatik.copyright = version .. "  " .. lunatik.copyright

print(lunatik.copyright)
lunatik.prompt()
for chunk in io.lines() do
	print(lunatik.dostring(chunk))
	lunatik.prompt()
end

